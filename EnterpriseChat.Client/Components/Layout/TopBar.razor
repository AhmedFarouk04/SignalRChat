@using EnterpriseChat.Client.Models
@using EnterpriseChat.Client.ViewModels
@using EnterpriseChat.Client.Services.Realtime
@using EnterpriseChat.Client.Authentication.Abstractions
@inject IChatRealtimeClient Realtime
@inject ICurrentUser CurrentUser
@implements IDisposable

<div class="topbar" @onclick="CloseMenuOnOutsideClick">
    @if (VM?.IsSearching == true)
    {
        <div class="search-mode">
            <button class="icon-btn" @onclick="() => VM.IsSearching = false">⬅️</button>
            <div class="search-input-wrapper">
                <input type="text" class="search-input" placeholder="Search in chat..."
                       @bind="VM.SearchQuery" @bind:event="oninput" autofocus />
                @if (VM.SearchResults.Any())
                {
                    <div class="search-results-dropdown">
                        @foreach (var res in VM.SearchResults)
                        {
                            <div class="search-item" @onclick="() => OnSearchResultClick(res.Id)">
                                <div class="search-item-text">@res.Content</div>
                                <div class="search-item-meta">@res.CreatedAt.ToLocalTime().ToString("MMM dd, h:mm tt")</div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        @if (Room is null)
        {
            <div class="room-header">
                <span class="room-title">Loading…</span>
            </div>
        }
        else
        {
            <div class="room-header">
                <div class="room-main">
                    <div class="room-title">@Title</div>
                    <div class="room-sub">
                        @if (IsPrivate && OtherUser != null)
                        {
                            @if (VM.IsBlockedByMe || VM.IsBlockedMe)
                            {
                                <span class="dot offline"></span>
                                <span>Offline</span>
                            }
                            else if (OtherUser.IsOnline)
                            {
                                <span class="dot online"></span>
                                <span>Online</span>
                            }
                            else if (OtherUser.LastSeen != null)
                            {
                                var lastSeen = OtherUser.LastSeen.Value.ToLocalTime();
                                var today = DateTime.Today;
                                var yesterday = today.AddDays(-1);
                                string lastSeenText;
                                if (lastSeen.Date == today)
                                    lastSeenText = $"Today at {lastSeen:t}";
                                else if (lastSeen.Date == yesterday)
                                    lastSeenText = $"Yesterday at {lastSeen:t}";
                                else
                                    lastSeenText = lastSeen.ToString("MMM dd, yyyy 'at' h:mm tt");
                                <span class="dot offline"></span>
                                <span>Last seen @lastSeenText</span>
                            }
                            else
                            {
                                <span class="dot offline"></span>
                                <span>Offline</span>
                            }
                        }
                        else
                        {
                            <span>@(VM?.GroupMembers?.Members?.Count ?? MembersCount) members</span>
                            <span>•</span>
                            <span>@(CurrentOnlineCount) online</span>
                        }
                    </div>
                </div>

                <div class="room-actions">
                    @* Search stays outside *@
                    <button class="icon-btn" title="Search" @onclick="() => VM.IsSearching = true" @onclick:stopPropagation="true">🔍</button>

                    @* Everything else inside ⋮ *@
                    <div class="chat-actions-wrapper" @onclick:stopPropagation="true">
                        <button class="icon-btn topbar-more-btn @(_actionsMenuOpen ? "active" : "")"
                                title="More options"
                                @onclick="ToggleActionsMenu">
                            ⋮
                        </button>

                        @if (_actionsMenuOpen)
                        {
                            @* ── Backdrop يغلق الـ dropdown لما تضغط برا ── *@
                            <div class="dropdown-backdrop" @onclick="CloseMenuOnOutsideClick"></div>

                            <div class="actions-dropdown">

                                @* Mute/Unmute *@
                                <button class="dropdown-item" @onclick="HandleMuteClick">
                                    <span class="di-icon">@(_localIsMuted ? "🔕" : "🔔")</span>
                                    <span>@(_localIsMuted ? "Unmute" : "Mute")</span>
                                </button>

                                @* Block/Unblock - Private only *@
                                @if (IsPrivate)
                                {
                                    <button class="dropdown-item @(IsBlockedByMe ? "warn" : "")" @onclick="HandleBlockClick">
                                        <span class="di-icon">@(IsBlockedByMe ? "🔓" : "🚫")</span>
                                        <span>@(IsBlockedByMe ? "Unblock" : "Block")</span>
                                    </button>
                                }

                                @* Members - Group only *@
                                @if (!IsPrivate)
                                {
                                    <button class="dropdown-item" @onclick="HandleMembersClick">
                                        <span class="di-icon">👥</span>
                                        <span>Members</span>
                                    </button>
                                }

                                <div class="dropdown-divider"></div>

                                @* Clear Chat *@
                                <button class="dropdown-item" @onclick="() => ShowConfirm(ConfirmAction.Clear)">
                                    <span class="di-icon">🧹</span>
                                    <span>Clear Chat</span>
                                </button>

                                @* Clear for Everyone - Group owner only *@
                                @if (!IsPrivate && VM?.GroupMembers?.OwnerId == _currentUserId)
                                {
                                    <button class="dropdown-item" @onclick="() => ShowConfirm(ConfirmAction.ClearAll)">
                                        <span class="di-icon">🧹</span>
                                        <span>Clear for Everyone</span>
                                    </button>
                                }

                                <div class="dropdown-divider"></div>

                                @* Delete *@
                                <button class="dropdown-item danger" @onclick="() => ShowConfirm(ConfirmAction.Delete)">
                                    <span class="di-icon">🗑️</span>
                                    <span>@(IsPrivate ? "Delete Chat" : "Delete Group")</span>
                                </button>

                            </div>
                        }
                    </div>
                </div>
            </div>

            @* ── Pinned Messages Bar ── *@
            @if (VM?.PinnedMessages != null && VM.PinnedMessages.Any())
            {
                var currentPinned = GetCurrentPinned();
                <div class="pinned-msg-bar" @onclick="RotatePinnedMessages">
                    <div class="pin-indicator-group">
                        <span class="pin-icon-small">📌</span>
                        @if (VM.PinnedMessages.Count > 1)
                        {
                            <span class="pin-count-text">@(_displayIndex + 1)/@VM.PinnedMessages.Count</span>
                        }
                    </div>
                    <div class="pin-preview-text">
                        <span style="color: var(--accent-main); font-weight: bold;">Pinned: </span>
                        @currentPinned.Content
                    </div>
                    <div style="display:flex; gap:4px; align-items:center;">
                        <button class="icon-btn" style="font-size: 10px;"
                                title="Go to message"
                                @onclick:stopPropagation="true"
                                @onclick="() => OnScrollToMessage.InvokeAsync(currentPinned.Id)">
                            ➡️
                        </button>
                        <button class="icon-btn" style="font-size: 10px; color: #ff6b6b;"
                                title="Unpin"
                                @onclick:stopPropagation="true"
                                @onclick="() => HandleUnpin(currentPinned.Id)">
                            ✕
                        </button>
                    </div>
                </div>
            }
        }
    }
</div>

@* ── Confirmation Dialog ── *@
@if (_confirmAction != ConfirmAction.None)
{
    <div class="confirm-overlay" @onclick="CancelConfirm">
        <div class="confirm-dialog" @onclick:stopPropagation="true">
            <div class="confirm-icon">@GetConfirmIcon()</div>
            <div class="confirm-title">@GetConfirmTitle()</div>
            <div class="confirm-body">@GetConfirmBody()</div>
            <div class="confirm-actions">
                <button class="confirm-btn cancel" @onclick="CancelConfirm">Cancel</button>
                <button class="confirm-btn @(_confirmAction == ConfirmAction.Delete ? "delete" : "clear")"
                        @onclick="ExecuteConfirm">
                    @GetConfirmLabel()
                </button>
            </div>
        </div>
    </div>
}



@code {
        [Parameter] public RoomModel? Room { get; set; }
    [Parameter] public ChatViewModel? VM { get; set; }
    [Parameter] public EventCallback<Guid> OnScrollToMessage { get; set; }
    [Parameter] public int MembersCount { get; set; }
    [Parameter] public int OnlineCount { get; set; }
    [Parameter] public UserModel? OtherUser { get; set; }
    [Parameter] public bool IsMuted { get; set; }
    [Parameter] public EventCallback OnMuteToggle { get; set; }
    [Parameter] public EventCallback OnBlock { get; set; }
    [Parameter] public EventCallback OnMembers { get; set; }
    [Parameter] public bool IsBlockedByMe { get; set; }
    [Parameter] public EventCallback OnUnblock { get; set; }
    [Parameter] public EventCallback OnDeleteChat { get; set; }
    [Parameter] public EventCallback OnClearChat { get; set; }
    [Parameter] public EventCallback OnClearChatForAll { get; set; }
    private bool _localIsMuted;

    protected override void OnParametersSet()
    {
        base.OnParametersSet();

        if (_localIsMuted != IsMuted)
        {
            _localIsMuted = IsMuted;
            StateHasChanged();           }
    }
        private bool _actionsMenuOpen = false;
    private Guid _currentUserId;
    private int _displayIndex = 0;

        private enum ConfirmAction { None, Clear, ClearAll, Delete }
    private ConfirmAction _confirmAction = ConfirmAction.None;

    private void ShowConfirm(ConfirmAction action)
    {
        _actionsMenuOpen = false;
        _confirmAction = action;
        StateHasChanged();
    }

    private void CancelConfirm()
    {
        _confirmAction = ConfirmAction.None;
        StateHasChanged();
    }

    private async Task ExecuteConfirm()
    {
        var action = _confirmAction;
        _confirmAction = ConfirmAction.None;
        StateHasChanged();

        switch (action)
        {
            case ConfirmAction.Clear: await OnClearChat.InvokeAsync(); break;
            case ConfirmAction.ClearAll: await OnClearChatForAll.InvokeAsync(); break;
            case ConfirmAction.Delete: await OnDeleteChat.InvokeAsync(); break;
        }
    }

    private string GetConfirmIcon() => _confirmAction == ConfirmAction.Delete ? "🗑️" : "🧹";

    private string GetConfirmTitle() => _confirmAction switch
    {
        ConfirmAction.Delete => IsPrivate ? "Delete Chat?" : "Delete Group?",
        ConfirmAction.ClearAll => "Clear for Everyone?",
        _ => "Clear Chat?"
    };

    private string GetConfirmBody() => _confirmAction switch
    {
        ConfirmAction.Delete => IsPrivate
            ? "This chat will be deleted for you only. The other person won't be notified."
            : "This will permanently delete the group and all its messages for everyone.",
        ConfirmAction.ClearAll => "All messages will be cleared for every member in this group. This cannot be undone.",
        _ => "All messages will be cleared for you only. This cannot be undone."
    };

    private string GetConfirmLabel() => _confirmAction switch
    {
        ConfirmAction.Delete => IsPrivate ? "Delete" : "Delete Group",
        ConfirmAction.ClearAll => "Clear for All",
        _ => "Clear"
    };

        private void ToggleActionsMenu()
    {
        _actionsMenuOpen = !_actionsMenuOpen;
        StateHasChanged();
    }

    private void CloseMenuOnOutsideClick()
    {
        if (_actionsMenuOpen)
        {
            _actionsMenuOpen = false;
            StateHasChanged();
        }
    }

    private async Task HandleMuteClick()
    {
        _actionsMenuOpen = false;
        await OnMuteToggle.InvokeAsync();
    }

    private async Task HandleBlockClick()
    {
        _actionsMenuOpen = false;
        await (IsBlockedByMe ? OnUnblock : OnBlock).InvokeAsync();
    }

    private async Task HandleMembersClick()
    {
        _actionsMenuOpen = false;
        await OnMembers.InvokeAsync();
    }

        private bool IsPrivate => Room?.Type == "Private";
    private string Title => IsPrivate ? Room?.OtherDisplayName ?? "Private Chat" : Room?.Name ?? "Group";
    private int CurrentOnlineCount => VM?.OnlineUsers?.Count ?? OnlineCount;

    private async Task HandleUnpin(Guid messageId)
    {
        if (VM != null)
            await VM.UnpinMessageAsync(messageId);
    }

        protected override async Task OnInitializedAsync()
    {
        var userId = await CurrentUser.GetUserIdAsync();
        _currentUserId = userId ?? Guid.Empty;
        Realtime.UserBlockedByMeChanged += OnBlockedByMe;
        Realtime.UserBlockedMeChanged += OnBlockedMe;
        Realtime.UserOnline += OnUserOnline;
        Realtime.UserOffline += OnUserOffline;
        Realtime.UserLastSeenUpdated += OnUserLastSeenUpdated;
        Realtime.RoomPresenceUpdated += OnRoomPresenceUpdated;

        if (VM != null)
            VM.Changed += OnViewModelChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        await InvokeAsync(StateHasChanged);
    }

        private void OnBlockedByMe(Guid userId, bool blocked)
    {
        if (OtherUser?.Id == userId)
        {
            if (blocked) { OtherUser.IsOnline = false; OtherUser.LastSeen = null; }
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnBlockedMe(Guid userId, bool blocked)
    {
        if (OtherUser?.Id == userId)
        {
            if (blocked) { OtherUser.IsOnline = false; OtherUser.LastSeen = null; }
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnUserOnline(Guid userId)
    {
        if (OtherUser?.Id == userId)
        {
            OtherUser.IsOnline = true;
            OtherUser.LastSeen = null;
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnUserOffline(Guid userId)
    {
        if (OtherUser?.Id == userId)
        {
            OtherUser.IsOnline = false;
            OtherUser.LastSeen = DateTime.UtcNow;
        }
        InvokeAsync(StateHasChanged);
    }

    private void OnUserLastSeenUpdated(Guid userId, DateTime lastSeen)
    {
        if (OtherUser?.Id == userId)
        {
            OtherUser.IsOnline = false;
            OtherUser.LastSeen = lastSeen;
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnRoomPresenceUpdated(Guid roomId, int count)
    {
        if (Room?.Id == roomId && !IsPrivate)
        {
            OnlineCount = count;
            InvokeAsync(StateHasChanged);
        }
    }

        private MessageModel GetCurrentPinned()
    {
        if (VM?.PinnedMessages == null || !VM.PinnedMessages.Any()) return null;
        if (_displayIndex >= VM.PinnedMessages.Count) _displayIndex = 0;
        return VM.PinnedMessages[_displayIndex];
    }

    private void RotatePinnedMessages()
    {
        if (VM?.PinnedMessages == null || !VM.PinnedMessages.Any()) return;
        if (VM.PinnedMessages.Count <= 1)
        {
            OnScrollToMessage.InvokeAsync(VM.PinnedMessages[0].Id);
            return;
        }
        _displayIndex++;
        if (_displayIndex >= VM.PinnedMessages.Count) _displayIndex = 0;
        StateHasChanged();
    }

    private async Task OnSearchResultClick(Guid messageId)
    {
        if (VM != null)
        {
            VM.IsSearching = false;
            await Task.Delay(100);
            await OnScrollToMessage.InvokeAsync(messageId);
        }
    }

    private void OnViewModelChanged()
    {
        InvokeAsync(StateHasChanged);
        Console.WriteLine($"[TopBar] ViewModel changed, online count: {VM?.OnlineUsers?.Count ?? 0}");
    }

    public void Dispose()
    {
        Realtime.UserOnline -= OnUserOnline;
        Realtime.UserOffline -= OnUserOffline;
        Realtime.UserLastSeenUpdated -= OnUserLastSeenUpdated;
        Realtime.RoomPresenceUpdated -= OnRoomPresenceUpdated;
        Realtime.UserBlockedByMeChanged -= OnBlockedByMe;
        Realtime.UserBlockedMeChanged -= OnBlockedMe;
        if (VM != null)
            VM.Changed -= OnViewModelChanged;
    }
}