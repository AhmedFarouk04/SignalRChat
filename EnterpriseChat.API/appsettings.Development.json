{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=EnterpriseChatDb;Trusted_Connection=True;TrustServerCertificate=True;",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Key": "ChangeThisVeryLongSecretKeyInProductionAndInUserSecrets",
    "Issuer": "EnterpriseChat",
    "Audience": "EnterpriseChat.Clients",
    "ExpiresMinutes": 60,
    "AccessTokenMinutes": 120
  },
  "Presence": {
    "Redis": "localhost:6379",
    "Provider": "Redis"
  },
  "Email": {
    "Smtp": {
      "Host": "smtp.gmail.com",
      "Port": 587,
      "Username": "your-email@gmail.com",
      "Password": "your-app-password-goes-here-in-user-secrets-or-env",
      "FromName": "EnterpriseChat",
      "FromEmail": "your-email@gmail.com"
    }
  },
  "AllowedHosts": "*"
}